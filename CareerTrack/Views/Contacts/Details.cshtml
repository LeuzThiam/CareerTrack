@model Contact

@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}";
}

<h1>@Model.FirstName @Model.LastName</h1>
<h5 class="text-muted">@Model.Company.Name</h5>

<dl class="row mt-3">
    <dt class="col-sm-2">Poste</dt>
    <dd class="col-sm-10">@Model.JobTitle</dd>

    <dt class="col-sm-2">Courriel</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Téléphone</dt>
    <dd class="col-sm-10">@Model.PhoneNumber</dd>

    <dt class="col-sm-2">LinkedIn</dt>
    <dd class="col-sm-10">@Model.LinkedInUrl</dd>

    <dt class="col-sm-2">Notes</dt>
    <dd class="col-sm-10">@Model.Notes</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Modifier</a>
<a asp-action="Index" class="btn btn-link">Retour à la liste</a>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
      onsubmit="return confirm('Supprimer ce contact ?');">
    <button type="submit" class="btn btn-outline-danger">Supprimer</button>
</form>
