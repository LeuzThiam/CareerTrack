@model JobOfferFormViewModel

@{
    ViewData["Title"] = "Ajouter une offre";
}

<h1>Ajouter une offre</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="CompanyId" class="form-label"></label>
                <select asp-for="CompanyId" class="form-select"
                        asp-items="@(new SelectList(Model.AvailableCompanies, "Id", "Name"))">
                    <option value="">-- Choisir une entreprise --</option>
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="WorkMode" class="form-label"></label>
                <select asp-for="WorkMode" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.WorkMode>()"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EmploymentType" class="form-label"></label>
                <select asp-for="EmploymentType" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.EmploymentType>()"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Source" class="form-label"></label>
                <select asp-for="Source" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.JobSource>()"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SourceUrl" class="form-label"></label>
                <input asp-for="SourceUrl" class="form-control" />
                <span asp-validation-for="SourceUrl" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col form-group mb-3">
                    <label asp-for="MinimumSalary" class="form-label"></label>
                    <input asp-for="MinimumSalary" class="form-control" />
                    <span asp-validation-for="MinimumSalary" class="text-danger"></span>
                </div>
                <div class="col form-group mb-3">
                    <label asp-for="MaximumSalary" class="form-label"></label>
                    <input asp-for="MaximumSalary" class="form-control" />
                    <span asp-validation-for="MaximumSalary" class="text-danger"></span>
                </div>
                <div class="col form-group mb-3">
                    <label asp-for="CurrencyCode" class="form-label"></label>
                    <input asp-for="CurrencyCode" class="form-control" placeholder="CAD" />
                    <span asp-validation-for="CurrencyCode" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col form-group mb-3">
                    <label asp-for="PublicationDate" class="form-label"></label>
                    <input asp-for="PublicationDate" class="form-control" />
                </div>
                <div class="col form-group mb-3">
                    <label asp-for="ClosingDate" class="form-label"></label>
                    <input asp-for="ClosingDate" class="form-control" />
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.JobOfferStatus>()"></select>
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-link">Annuler</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
