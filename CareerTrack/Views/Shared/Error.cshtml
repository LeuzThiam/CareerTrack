@model ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<h1 class="text-danger">Une erreur est survenue</h1>
<p>Une erreur inattendue s'est produite pendant le traitement de votre demande. L'équipe technique a été notifiée.</p>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Référence :</strong> <code>@Model.RequestId</code>
    </p>
    <p class="text-muted">Conserve cette référence si tu signales le problème — elle permet de retrouver les détails techniques dans les journaux.</p>
}
