@model JobApplicationFormViewModel

@{
    ViewData["Title"] = "Ajouter une candidature";
}

<h1>Ajouter une candidature</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="CompanyId" class="form-label"></label>
                <select asp-for="CompanyId" class="form-select"
                        asp-items="@(new SelectList(Model.AvailableCompanies, "Id", "Name"))">
                    <option value="">-- Choisir une entreprise --</option>
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="JobOfferId" class="form-label"></label>
                <select asp-for="JobOfferId" class="form-select"
                        asp-items="@(new SelectList(Model.AvailableJobOffers, "Id", "Title"))">
                    <option value="">-- Candidature spontanée (aucune offre) --</option>
                </select>
                <span asp-validation-for="JobOfferId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="JobTitle" class="form-label"></label>
                <input asp-for="JobTitle" class="form-control" />
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AppliedOn" class="form-label"></label>
                <input asp-for="AppliedOn" class="form-control" />
                <span asp-validation-for="AppliedOn" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.ApplicationStatus>()"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Priority" class="form-label"></label>
                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.ApplicationPriority>()"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Source" class="form-label"></label>
                <select asp-for="Source" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.JobSource>()"></select>
            </div>

            <div class="row">
                <div class="col form-group mb-3">
                    <label asp-for="ExpectedSalary" class="form-label"></label>
                    <input asp-for="ExpectedSalary" class="form-control" />
                    <span asp-validation-for="ExpectedSalary" class="text-danger"></span>
                </div>
                <div class="col form-group mb-3">
                    <label asp-for="CurrencyCode" class="form-label"></label>
                    <input asp-for="CurrencyCode" class="form-control" placeholder="CAD" />
                    <span asp-validation-for="CurrencyCode" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-link">Annuler</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
