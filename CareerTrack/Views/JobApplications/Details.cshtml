@model JobApplication
@{
    ViewData["Title"] = Model.JobTitle;
    var changeStatus = (ChangeStatusViewModel)ViewData["ChangeStatus"]!;
    var error = TempData["ChangeStatusError"] as string;
    var followUps = (List<FollowUp>)ViewData["FollowUps"]!;
    var newFollowUp = (FollowUpFormViewModel)ViewData["NewFollowUp"]!;
    var followUpError = TempData["FollowUpError"] as string;
    var interviews = (List<Interview>)ViewData["Interviews"]!;
    var newInterview = (InterviewFormViewModel)ViewData["NewInterview"]!;
    var interviewError = TempData["InterviewError"] as string;
}

<h1>@Model.JobTitle</h1>
<h5 class="text-muted">@Model.Company.Name</h5>

<dl class="row mt-3">
    <dt class="col-sm-3">Statut actuel</dt>
    <dd class="col-sm-9"><span class="badge bg-primary">@Model.Status</span></dd>

    <dt class="col-sm-3">Priorité</dt>
    <dd class="col-sm-9">@Model.Priority</dd>

    <dt class="col-sm-3">Source</dt>
    <dd class="col-sm-9">@Model.Source</dd>

    <dt class="col-sm-3">Offre associée</dt>
    <dd class="col-sm-9">@(Model.JobOffer?.Title ?? "Aucune (candidature spontanée)")</dd>

    <dt class="col-sm-3">Date d'envoi</dt>
    <dd class="col-sm-9">@Model.AppliedOn</dd>

    <dt class="col-sm-3">Salaire demandé</dt>
    <dd class="col-sm-9">@Model.ExpectedSalary @Model.CurrencyCode</dd>

    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Modifier</a>
<a asp-action="Index" class="btn btn-link">Retour à la liste</a>
<form asp-action="Archive" asp-route-id="@Model.Id" method="post" class="d-inline"
      onsubmit="return confirm('Archiver cette candidature ?');">
    <button type="submit" class="btn btn-outline-danger">Archiver</button>
</form>

<hr />

<h3>Changer le statut</h3>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}

@if (changeStatus.AvailableStatuses.Any())
{
    <form asp-action="ChangeStatus" method="post" class="row g-2 align-items-end mb-4" style="max-width: 700px;">
        <input type="hidden" name="ApplicationId" value="@changeStatus.ApplicationId" />
        <div class="col-auto">
            <label class="form-label">Nouveau statut</label>
            <select name="NewStatus" class="form-select">
                @foreach (var status in changeStatus.AvailableStatuses)
                {
                    <option value="@((int)status)">@status</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">Commentaire</label>
            <input type="text" name="Comment" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Changer le statut</button>
        </div>
    </form>
}
else
{
    <p class="text-muted">Cette candidature est dans un statut terminal, aucune transition n'est disponible.</p>
}

<h3>Historique</h3>

<table class="table table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Ancien statut</th>
            <th>Nouveau statut</th>
            <th>Commentaire</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var entry in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
        {
            <tr>
                <td>@entry.ChangedAt.ToLocalTime()</td>
                <td>@(entry.PreviousStatus?.ToString() ?? "—")</td>
                <td>@entry.NewStatus</td>
                <td>@entry.Comment</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h3>Relances</h3>

@if (!string.IsNullOrEmpty(followUpError))
{
    <div class="alert alert-danger">@followUpError</div>
}

<table class="table table-sm">
    <thead>
        <tr>
            <th>Type</th>
            <th>Date prévue</th>
            <th>Statut</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var followUp in followUps)
        {
            <tr>
                <td>@followUp.Type</td>
                <td>@followUp.ScheduledAt.ToLocalTime()</td>
                <td>@(followUp.IsCompleted ? $"Terminée — {followUp.Result}" : "En attente")</td>
                <td>
                    @if (!followUp.IsCompleted)
                    {
                        <form asp-controller="FollowUps" asp-action="Complete" method="post" class="d-inline">
                            <input type="hidden" name="FollowUpId" value="@followUp.Id" />
                            <input type="hidden" name="ApplicationId" value="@Model.Id" />
                            <input type="text" name="Result" class="form-control form-control-sm d-inline w-auto" placeholder="Résultat (optionnel)" />
                            <button type="submit" class="btn btn-sm btn-outline-success">Marquer terminée</button>
                        </form>
                        <form asp-controller="FollowUps" asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Supprimer cette relance ?');">
                            <input type="hidden" name="FollowUpId" value="@followUp.Id" />
                            <input type="hidden" name="ApplicationId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!followUps.Any())
        {
            <tr><td colspan="4" class="text-muted">Aucune relance planifiée.</td></tr>
        }
    </tbody>
</table>

<h5>Planifier une relance</h5>
<form asp-controller="FollowUps" asp-action="Create" method="post" class="row g-2 align-items-end mb-4" style="max-width: 700px;">
    <input type="hidden" name="ApplicationId" value="@newFollowUp.ApplicationId" />
    <div class="col-auto">
        <label class="form-label">Type</label>
        <select name="Type" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.FollowUpType>()"></select>
    </div>
    <div class="col-auto">
        <label class="form-label">Date prévue</label>
        <input type="datetime-local" name="ScheduledAt" class="form-control" />
    </div>
    <div class="col-auto">
        <label class="form-label">Notes</label>
        <input type="text" name="Notes" class="form-control" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Planifier</button>
    </div>
</form>

<hr />

<h3>Entrevues</h3>

@if (!string.IsNullOrEmpty(interviewError))
{
    <div class="alert alert-danger">@interviewError</div>
}

<table class="table table-sm">
    <thead>
        <tr>
            <th>Type</th>
            <th>Date</th>
            <th>Statut</th>
            <th>Résultat</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var interview in interviews)
        {
            <tr>
                <td>@interview.Type</td>
                <td>@interview.ScheduledAt.ToLocalTime()</td>
                <td>@interview.Status</td>
                <td>@interview.Result</td>
                <td>
                    @if (interview.Status is CareerTrack.Models.Enums.InterviewStatus.Scheduled or CareerTrack.Models.Enums.InterviewStatus.Rescheduled)
                    {
                        <form asp-controller="Interviews" asp-action="Complete" method="post" class="d-inline">
                            <input type="hidden" name="InterviewId" value="@interview.Id" />
                            <input type="hidden" name="ApplicationId" value="@Model.Id" />
                            <input type="hidden" name="Status" value="2" />
                            <input type="text" name="Result" class="form-control form-control-sm d-inline w-auto" placeholder="Résultat" />
                            <button type="submit" class="btn btn-sm btn-outline-success">Marquer terminée</button>
                        </form>
                        <form asp-controller="Interviews" asp-action="Cancel" method="post" class="d-inline"
                              onsubmit="return confirm('Annuler cette entrevue ?');">
                            <input type="hidden" name="interviewId" value="@interview.Id" />
                            <input type="hidden" name="applicationId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Annuler</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!interviews.Any())
        {
            <tr><td colspan="5" class="text-muted">Aucune entrevue planifiée.</td></tr>
        }
    </tbody>
</table>

<h5>Planifier une entrevue</h5>
<form asp-controller="Interviews" asp-action="Create" method="post" class="row g-2 align-items-end mb-4" style="max-width: 900px;">
    <input type="hidden" name="ApplicationId" value="@newInterview.ApplicationId" />
    <div class="col-auto">
        <label class="form-label">Type</label>
        <select name="Type" class="form-select" asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.InterviewType>()"></select>
    </div>
    <div class="col-auto">
        <label class="form-label">Date et heure</label>
        <input type="datetime-local" name="ScheduledAt" class="form-control" />
    </div>
    <div class="col-auto">
        <label class="form-label">Durée (min)</label>
        <input type="number" name="DurationMinutes" class="form-control" style="width: 100px;" />
    </div>
    <div class="col-auto">
        <label class="form-label">Lieu</label>
        <input type="text" name="Location" class="form-control" />
    </div>
    <div class="col-auto">
        <label class="form-label">Lien visio</label>
        <input type="text" name="MeetingUrl" class="form-control" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Planifier</button>
    </div>
</form>
